    "tags.detail.limitation.alert.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro-Benutzer können unbegrenzt viele Tags erstellen (über das Limit von 5 Tags hinaus)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro users can create unlimited tags (beyond the 5-tag limit)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los usuarios de Pro pueden crear etiquetas ilimitadas (más allá del límite de 5 etiquetas)."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
