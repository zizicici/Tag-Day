    "backup.section.toggle.hint" : {
      "comment" : "The database file will be automatically backed up to the 'Tag Day' folder in iCloud. Up to once per day.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Datenbankdatei wird automatisch im Ordner „Tag Day\" in iCloud gesichert. Bis zu einmal pro Tag."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The database file will be automatically backed up to the 'Tag Day' folder in iCloud. Up to once per day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se realizará una copia de seguridad del archivo de base de datos automáticamente en la carpeta 'Tag Day' en iCloud. Hasta una vez por día."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se realizará una copia de seguridad del archivo de base de datos automáticamente en la carpeta 'Tag Day' en iCloud. Hasta una vez por día."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le fichier de base de données sera automatiquement sauvegardé dans le dossier « Tag Day » dans iCloud. Jusqu'à une fois par jour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verrà eseguito automaticamente il backup del file del database nella cartella \"Tag Day\" in iCloud. Fino a una volta al giorno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データベース ファイルは、iCloud の「Tag Day」フォルダーに自動的にバックアップされます。 1日1回まで。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "데이터베이스 파일은 iCloud의 'Tag Day' 폴더에 자동으로 백업됩니다. 하루에 한 번까지 가능합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Será feito automaticamente um backup do arquivo do banco de dados na pasta 'Tag Day' no iCloud. No máximo uma vez por dia."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Será criada automaticamente uma cópia de segurança do ficheiro da base de dados na pasta 'Tag Day' no iCloud. No máximo uma vez por dia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Резервная копия файла базы данных будет автоматически сохранена в папке «Tag Day» в iCloud. До одного раза в день."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Файл бази даних буде автоматично скопійовано в папку «Tag Day» у iCloud. До одного разу на день."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数据库文件将会自动同步到iCloud里的'Tag Day'文件夹。每天最多备份一次。"
